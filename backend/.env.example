# ── Server ──────────────────────────────────────────────
# NODE_ENV: development | test | production
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/prod_pilot

# ── JWT Secret (use a long random string in production) ──
JWT_ACCESS_SECRET=replace_with_long_random_access_secret

# ── Token TTL ────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m

# ── Cookie / CORS ────────────────────────────────────────
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# Base URL of the frontend — used to build password-reset links.
FRONTEND_URL=http://localhost:5173

# ── AI API Keys (get your own keys) ──────────────────────
# HuggingFace: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_api_key_here

# NVIDIA NIM / Mistral: https://build.nvidia.com
NVIDIA_API_KEY=nvapi_your_nvidia_api_key_here

# ── Email delivery (password reset) — optional, degrades to a logged no-op ──
# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=PROD PILOT <onboarding@resend.dev>

# ── Error monitoring — optional, Sentry SDK no-ops without a DSN ─────────────
# Sentry: https://sentry.io → Settings → Projects → <project> → Client Keys (DSN)
SENTRY_DSN=
