# ── Server ──────────────────────────────────────────────
PORT=4000

# ── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/prod_pilot

# ── JWT Secrets (use long random strings in production) ──
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# ── Token TTLs ───────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookie / CORS ────────────────────────────────────────
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# ── AI API Keys (get your own keys) ──────────────────────
# HuggingFace: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_api_key_here

# NVIDIA NIM / Mistral: https://build.nvidia.com
NVIDIA_API_KEY=nvapi_your_nvidia_api_key_here
