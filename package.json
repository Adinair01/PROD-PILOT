{
  "name": "prodpilot",
  "version": "1.0.0",
  "description": "Pre-development decision intelligence platform — captures role-specific engineering feedback, analyzes sentiment, and generates AI-grounded go/no-go decisions for product teams.",
  "scripts": {
    "dev": "node --watch ./backend/src/server.js",
    "start": "node ./backend/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"backend/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"backend/**/*.js\" \"tests/**/*.js\""
  },
  "keywords": [
    "product-management",
    "decision-intelligence",
    "feedback",
    "sentiment-analysis",
    "express",
    "mongodb",
    "react"
  ],
  "author": "Aditya Nair",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@sentry/node": "^10.66.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "resend": "^6.17.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.13.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
